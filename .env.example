# Required: absolute path to your local instruct model directory (e.g. Qwen 3.5 9B)
MODEL_PATH=/absolute/path/to/model

# Optional: directory where notes are saved and read (default: ~/notes)
# Point this at your Obsidian vault or preferred notes folder
NOTES_DIR=~/notes

# Optional: Whisper model size — tiny, base, small, medium (default: small)
WHISPER_MODEL=small
